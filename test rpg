<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CodeReview Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: Arial; margin: 0; background: #0f172a; color: #e2e8f0; }
    header { background: #1e293b; padding: 15px; text-align: center; font-size: 24px; }
    .container { padding: 20px; max-width: 900px; margin: auto; }
    textarea, input { width: 100%; padding: 10px; margin-top: 10px; border-radius: 8px; border: none; }
    button { margin-top: 10px; padding: 10px 15px; border: none; border-radius: 8px; background: #38bdf8; cursor: pointer; }
    .post { background: #1e293b; padding: 15px; border-radius: 10px; margin-top: 20px; }
    .review { background: #334155; padding: 10px; border-radius: 8px; margin-top: 10px; }
  </style>
</head>
<body>
  <header>💻 CodeReview Hub</header>

  <div class="container">
    <h2>Post Your Code</h2>
    <input id="title" placeholder="Project title" />
    <textarea id="code" rows="6" placeholder="Paste your code here..."></textarea>
    <button onclick="addPost()">Post</button>

    <div id="posts"></div>
  </div>

  <script>
    let posts = [];

    function addPost() {
      const title = document.getElementById('title').value;
      const code = document.getElementById('code').value;

      if (!title || !code) return alert('Fill in both fields');

      posts.push({ title, code, reviews: [] });
      renderPosts();
    }

    function addReview(index) {
      const input = document.getElementById('review-' + index);
      if (!input.value) return;

      posts[index].reviews.push(input.value);
      input.value = '';
      renderPosts();
    }

    function renderPosts() {
      const container = document.getElementById('posts');
      container.innerHTML = '';

      posts.forEach((post, index) => {
        const div = document.createElement('div');
        div.className = 'post';

        div.innerHTML = `
          <h3>${post.title}</h3>
          <pre>${post.code}</pre>

          <h4>Reviews</h4>
          ${post.reviews.map(r => `<div class="review">${r}</div>`).join('')}

          <input id="review-${index}" placeholder="Write a review..." />
          <button onclick="addReview(${index})">Submit Review</button>
        `;

        container.appendChild(div);
      });
    }
  </script>
</body>
</html>
